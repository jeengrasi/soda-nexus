#!/data/data/com.termux/files/usr/bin/bash
ROOT="$HOME/soda"
REPORT="$HOME/soda/05-LOGS/SYSTEM/tree_$(date +%Y%m%d_%H%M).log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$REPORT"
}

log "=== INICIO DE AUDITORÍA DEL SISTEMA SODA‑NEXUS ==="

log "Carpetas principales:"
for d in 00-VAULT 01-DATA 02-SISTEMA 02-SCRIPTS 03-MODULOS 04-WEBAPP 05-LOGS; do
    if [ -d "$ROOT/$d" ]; then
        log "✔ $d existe"
    else
        log "❌ $d NO existe"
    fi
done

log ""
log "Árbol completo con permisos:"
tree -pugDh "$ROOT" | tee -a "$REPORT"

log ""
log "Archivos vacíos o sospechosos:"
find "$ROOT" -type f -size 0 -print | tee -a "$REPORT"

log ""
log "Scripts sin permisos de ejecución:"
find "$ROOT" -type f -name "*.sh" ! -perm -111 -print | tee -a "$REPORT"

log ""
log "Servicios runit activos:"
sv status | tee -a "$REPORT"

log ""
log "Tamaño total del sistema:"
du -sh "$ROOT" | tee -a "$REPORT"

log ""
log "=== FIN DE AUDITORÍA ==="
log "Reporte guardado en: $REPORT"

